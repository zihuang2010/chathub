# ─────────────────────────────────────────────────────────────
# chathub-relay 环境变量模板(生产)
#
# 用法:
#   cp scripts/.env.example scripts/.env.production   # 复制成真实配置
#   # 编辑 .env.production,把所有 REPLACE_ME 替换为真实值
#   scripts/run-relay-prod.sh                          # 启动(脚本会 source 本文件并 exec 二进制)
#
# 重要:
#   - 配置全部在 relay 进程「启动时」从环境变量读取(见 config.rs::Config::from_env),
#     与 cargo build 无关 —— 同一个 release 二进制可跑任意环境,环境差异只在本文件里。
#   - .env.production 含明文 secret,已被 .gitignore 忽略,切勿提交;本模板(.env.example)可提交。
# ─────────────────────────────────────────────────────────────

# ========== 必填 ==========
# 下游业务后台静态 base_url;也是 Nacos 发现失败时的兜底。
# 第一版内网用 http(已开 RELAY_ALLOW_HTTP=true);将来对外暴露请改 https。
RELAY_DOWNSTREAM_URL=https://proxy-dev.jdd51.com
# push 回调鉴权 secret(生产建议 ≥ 32 字符)。secret 直接写在本文件。
RELAY_PUSH_SECRET=a8d4f9c7e2b16a3d5f8c9e1b7a4d2c6f9e3a5b7c1d8e2f4a

# ========== 监听地址(对外服务需绑 0.0.0.0)==========
RELAY_GRPC_ADDR=0.0.0.0:50051
RELAY_PUSH_ADDR=0.0.0.0:50052

# ========== 传输安全 ==========
# 第一版仅内网部署,暂不启用 TLS:RELAY_ALLOW_HTTP=true 允许 http(含客户端 Bearer token 明文上行)。
# 仅限内网可信网络;将来对外暴露务必改回 TLS —— 加 RELAY_TLS_CERT_PATH / RELAY_TLS_KEY_PATH(成对)并删掉本项。
RELAY_ALLOW_HTTP=true

# ========== OAuth client(生产必须覆盖 dev 默认值)==========
RELAY_OAUTH_CLIENT_ID=rh_wxchat
RELAY_OAUTH_CLIENT_SECRET=9f3a2b1c-4d5e-4f6a-8b7c-2d3e4f5a6b7c

# ========== 存储 / 日志 ==========
RELAY_DB_PATH=/var/lib/chathub-relay/relay.db
RELAY_LOG_DIR=/var/log/chathub-relay
RELAY_LOG_FILE_PREFIX=relay
# off | compact | pretty | json。容器/集中采集建议 json。
RELAY_LOG_STDOUT=json
RELAY_EVENT_RETENTION_DAYS=7

# ========== 调优(可选;留空即用代码默认值)==========
# RELAY_PUSH_MAX_BODY_BYTES=1048576
# RELAY_FORCE_CLOSE_GRACE_MS=2000
# RELAY_ALLOWED_CLIENT_IDS=rh_wxchat
# RELAY_AUTH_CACHE_MAX_ENTRIES=10000
# RELAY_NOTIFY_PULL_ENABLED=true
# RELAY_NOTIFY_PULL_PAGE_SIZE=100
# RELAY_NOTIFY_PULL_MAX_ITERS=50
# RELAY_NOTIFY_PULL_BUDGET_MS=4000

# ========== Nacos 服务注册 / 发现 ==========
# 不用 Nacos:保持 false(或整段删掉),走纯静态 RELAY_DOWNSTREAM_URL,零行为变化。
RELAY_NACOS_ENABLED=true
#
# ↓↓↓ 仅当 RELAY_NACOS_ENABLED=true 时以下才生效 ↓↓↓
#
# 必填:Nacos server 地址(host:8848,集群用逗号分隔)。注意 rust nacos-sdk 走 gRPC,目标机需放通 9848。
RELAY_NACOS_SERVER_ADDR=REPLACE_ME:8848
# 必填:下游业务后台在 Nacos 的服务名。
RELAY_NACOS_DISCOVERY_SERVICE=REPLACE_ME
# 命名空间(空 = public)与分组(默认 DEFAULT_GROUP);注册与发现共用 group。
RELAY_NACOS_NAMESPACE=
RELAY_NACOS_GROUP=DEFAULT_GROUP
# Nacos 开了 HTTP 鉴权才需要(secret 直接写本文件):
# RELAY_NACOS_USERNAME=nacos
# RELAY_NACOS_PASSWORD=REPLACE_ME
# 下游发现拼 base_url 用的 scheme:第一版内网用 http(已开 RELAY_ALLOW_HTTP=true);将来对外暴露改 https。
RELAY_NACOS_DISCOVERY_SCHEME=http
# relay 自身注册的服务名。
RELAY_NACOS_REGISTER_SERVICE=chathub-relay-app
# 注册 IP:不设则自动探测本地/容器出口 IP(push_addr 绑 0.0.0.0 时也能拿到正确网卡 IP)。
# 仅当容器经 NAT 端口映射、且业务后台在容器外不可达时,才显式填后台可达的 relay IP。
# RELAY_NACOS_REGISTER_IP=
# 注册端口默认 = RELAY_PUSH_ADDR 的端口(本例 50052),后台按此端口回调 push。
# 仅当存在端口映射(容器 host→container、或 LB 前端端口与监听端口不一致)时才需显式覆盖。
# RELAY_NACOS_REGISTER_PORT=50052
# RELAY_NACOS_REGISTER_WEIGHT=1.0
# 注册实例元数据(k=v,k2=v2),随实例注册进 Nacos,供业务后台发现后据此回调。
# 默认带上 push 回调路径 / 健康检查路径 / scheme(第一版内网 http)。
# 注意:键名需与业务后台读取约定一致;勿放 secret(metadata 任何查询方可见)。
RELAY_NACOS_REGISTER_METADATA=pushPath=/rpc/v1/wecomAggregate/notify/push,healthPath=/healthz,scheme=http
