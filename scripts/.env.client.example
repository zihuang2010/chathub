# ─────────────────────────────────────────────────────────────
# chathub 客户端「编译期」环境变量模板(本地联调 / 本地打包共用)
#
# 用法:
#   cp scripts/.env.client.example scripts/.env.client   # 复制成真实配置
#   # 编辑 .env.client,填入真实 CHATHUB_AI_API_KEY
#   scripts/run-tauri-local.sh   或   scripts/build-windows.sh   # 脚本会自动 source 本文件
#
# 重要:
#   - 这些是【编译期】env,被 backends/build.rs 烘进客户端二进制(运行时由 ai_polish.rs
#     用 env!("..._RESOLVED") 读取)。改了它 cargo 会自动重编 backends。
#     —— 与 relay 服务端的 .env.production(进程启动时读)是两条完全不同的线。
#   - .env.client 含明文密钥,已被 .gitignore 忽略(.env.* 规则),切勿提交;
#     本模板(.env.client.example)不含 secret,可提交。
#   - CI 官方出包不读本文件:密钥走 GitHub Secret,见 .github/workflows/build.yml。
# ─────────────────────────────────────────────────────────────

# ========== AI 润色(OpenAI 兼容端点)==========
# 密钥(必填)。缺失或留空 → 客户端 AI 润色会显示「AI 未配置」。
# 默认对接通义千问(dashscope):到 https://bailian.console.aliyun.com 申请 sk- 开头的 API Key。
export CHATHUB_AI_API_KEY=sk-0b5c8dc438014ccc8b1e6aea206362fd

# 以下两项可选,留空即用 build.rs 默认值(通义千问端点 + qwen-flash):
# 仅当换其它 OpenAI 兼容厂商时才需覆盖(base_url 必须与 key 配套)。
export CHATHUB_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
export CHATHUB_AI_MODEL=qwen-flash
